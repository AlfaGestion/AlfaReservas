CI_ENVIRONMENT = development

# Public application URLs
app.baseURL = 'https://example.com/'
app.apiBaseURL = 'https://example.com/'

# Mercado Pago
MP_VERIFY_SSL = 1
MP_BACK_URL_BASE = 'https://example.com/'
MP_PUBLIC_KEY_TEST = 'your-mercado-pago-public-key'
MP_ACCESS_TOKEN_TEST = 'your-mercado-pago-access-token'

# Default tenant database
database.default.hostname = localhost
database.default.database = your_database_name
database.default.username = your_database_user
database.default.password = your_database_password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Shared AlfaReserva database
database.alfareserva.hostname = localhost
database.alfareserva.database = your_alfareserva_database
database.alfareserva.username = your_alfareserva_user
database.alfareserva.password = your_alfareserva_password
database.alfareserva.DBDriver = MySQLi
database.alfareserva.DBPrefix =
database.alfareserva.port = 3306

# Operational accounts
MASTER_ADMIN_EMAIL = admin@example.com
